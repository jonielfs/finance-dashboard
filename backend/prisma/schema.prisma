generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  cards     CreditCard[]
  goals     Goal[]
}

model CreditCard {
  id     Int    @id @default(autoincrement())
  name   String

  userId Int
  user   User @relation(fields: [userId], references: [id])

  invoices  Invoice[]
  purchases Purchase[]
}

model Invoice {
  id            Int      @id @default(autoincrement())
  referenceDate DateTime   // 👈 importante pra gráficos
  totalAmount   Decimal  @db.Decimal(10, 2)

  status        String   @default("OPEN")

  cardId Int
  card   CreditCard @relation(fields: [cardId], references: [id])
}

model Purchase {
  id           Int      @id @default(autoincrement())
  description  String
  totalAmount  Decimal  @db.Decimal(10, 2)
  installments Int
  purchaseDate DateTime

  cardId Int
  card   CreditCard @relation(fields: [cardId], references: [id])

  installmentsList Installment[]
}

model Installment {
  id        Int      @id @default(autoincrement())
  number    Int
  amount    Float
  dueDate   DateTime
  paid      Boolean  @default(false)

  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
}

model Goal {
  id        Int      @id @default(autoincrement())
  value     Decimal  @db.Decimal(10, 2)

  userId Int   @unique
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}